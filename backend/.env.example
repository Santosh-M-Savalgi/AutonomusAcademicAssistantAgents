# AAA v2 Backend — Environment Configuration
# Copy this to .env and fill in your values

APP_ENV=development
APP_NAME=AAA v2 Backend
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

CORS_ORIGINS_RAW=http://localhost:5173

# --- Database ---
POSTGRES_DSN=postgresql+asyncpg://aaa:aaa_password@postgres:5432/aaa
REDIS_URL=redis://redis:6379/0

# --- Vector Store ---
CHROMA_HOST=chroma
CHROMA_PORT=8000

# --- Object Storage ---
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=minio_access_key
OBJECT_STORAGE_SECRET_KEY=minio_secret_key
OBJECT_STORAGE_HEALTH_PATH=/minio/health/ready

# --- Authentication ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-strong-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# --- Rate Limiting ---
ENABLE_RATE_LIMIT=true

# --- Observability ---
SLOW_REQUEST_THRESHOLD_MS=500
OTEL_EXPORTER_OTLP_ENDPOINT=
