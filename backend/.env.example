# Required for Gemini generation and embeddings.
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Required for web search. Search failures fall back to Gemini knowledge.
TAVILY_API_KEY=replace-with-your-tavily-api-key

# Local persistence paths, relative to the process working directory.
SQLITE_DB_PATH=./data/aaa.db
CHROMA_DB_PATH=./chroma_store

# Comma-separated frontend origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:5173
