APP_NAME="AAA v2 Backend"
APP_ENV=development
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS_RAW=http://localhost:5173

# Legacy v1 local flow placeholders retained during additive migration.
GEMINI_API_KEY=replace-with-your-gemini-api-key
TAVILY_API_KEY=replace-with-your-tavily-api-key
SQLITE_DB_PATH=./data/aaa.db
CHROMA_DB_PATH=./chroma_store
ALLOWED_ORIGINS=http://localhost:5173

POSTGRES_DSN=postgresql+asyncpg://aaa:aaa_password@postgres:5432/aaa
REDIS_URL=redis://redis:6379/0

CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_SSL=false

OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_HEALTH_PATH=/minio/health/ready

DEPENDENCY_CHECK_TIMEOUT_SECONDS=2.0
ENABLE_RATE_LIMIT=false
